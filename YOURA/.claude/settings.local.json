{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "YouRA hook settings generated by install_hooks.py",
  "_usage": "Run `python install_hooks.py --install-deps` from the target environment after moving this repository.",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "'/path/to/your/YouRA/.venv_readme_check/bin/python' '/path/to/your/YouRA/YOURA/.claude/hooks/hook_router.py'",
            "timeout": 1200
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "'/path/to/your/YouRA/.venv_readme_check/bin/python' '/path/to/your/YouRA/YOURA/.claude/hooks/guard_bash.py'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
