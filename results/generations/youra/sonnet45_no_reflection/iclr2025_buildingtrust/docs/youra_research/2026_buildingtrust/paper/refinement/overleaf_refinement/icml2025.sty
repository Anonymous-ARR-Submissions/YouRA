% Minimal ICML 2025 style file (fallback for compilation)
% For actual submission, replace with official icml2025.sty from ICML website

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{icml2025}[2025/01/01 ICML 2025 Minimal Style]

% Page geometry
\usepackage[letterpaper,margin=1in]{geometry}

% Basic formatting
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[C]{ICML 2025 Submission}
\fancyfoot[C]{\thepage}

% Section formatting
\usepackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}

% Title formatting
\renewcommand{\maketitle}{%
  \begin{center}
    {\LARGE\bfseries\@title\par}
    \vskip 1em
    {\large\@author\par}
    \vskip 1em
  \end{center}
}

% Bibliography style placeholder
\newcommand{\icmlname}{ICML}

\endinput
