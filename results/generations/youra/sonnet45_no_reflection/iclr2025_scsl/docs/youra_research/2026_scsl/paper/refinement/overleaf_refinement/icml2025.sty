% Minimal ICML 2025 Style File for PDF Generation
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{icml2025}[2025/01/01 ICML 2025 Submission Template]

% Options
\newif\if@icmlpreprint
\DeclareOption{preprint}{\@icmlpreprinttrue}
\DeclareOption{accepted}{\@icmlpreprintfalse}
\ProcessOptions\relax

% Page layout
\RequirePackage[letterpaper,margin=1in]{geometry}
\RequirePackage{times}

% Title and author macros
\def\icmltitlerunning#1{\gdef\@icmltitlerunning{#1}}
\def\icmltitle#1{\gdef\@icmltitle{#1}}
\def\icmlsetsymbol#1#2{}
\def\icmlauthor#1#2{#1}
\newenvironment{icmlauthorlist}{}{}
\def\icmlaffiliation#1#2{}
\def\icmlcorrespondingauthor#1#2{}
\def\icmlkeywords#1{\gdef\@icmlkeywords{#1}}
\def\icmlEqualContribution{}
\def\printAffiliationsAndNotice#1{%
  \begin{center}
    {\Large\bfseries \@icmltitle\par}
    \vskip 1em
  \end{center}
}

% Two-column wrapper
\renewenvironment{twocolumn}[1][\@empty]{#1}{}

\endinput
