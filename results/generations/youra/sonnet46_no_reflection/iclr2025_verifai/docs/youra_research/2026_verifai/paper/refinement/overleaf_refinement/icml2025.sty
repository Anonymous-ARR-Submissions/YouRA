%% icml2025.sty - Minimal compatibility stub for local compilation
%% Replace with official ICML 2025 style file before Overleaf upload
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{icml2025}[2025/01/01 ICML 2025 Style Stub]

\DeclareOption{accepted}{}
\DeclareOption{submitted}{}
\ProcessOptions\relax

\RequirePackage[letterpaper,top=1in,bottom=1in,left=1in,right=1in]{geometry}
\RequirePackage{times}
\RequirePackage{natbib}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}

% Title/author commands (no-ops for stub)
\newcommand{\icmltitle}[1]{\title{#1}}
\newcommand{\icmltitlerunning}[1]{}
\newcommand{\icmlsetsymbol}[2]{}
\newenvironment{icmlauthorlist}{}{}
\newcommand{\icmlauthor}[2]{#1}
\newcommand{\icmlaffiliation}[2]{}
\newcommand{\icmlcorrespondingauthor}[2]{}
\newcommand{\icmlkeywords}[1]{}
\newcommand{\printAffiliationsAndNotice}[1]{}

% Abstract
\renewenvironment{abstract}{%
  \noindent\textbf{Abstract.}\ \ignorespaces
}{\par}

% Section formatting
\titleformat{\section}{\large\bfseries}{\thesection.}{0.5em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection.}{0.5em}{}
