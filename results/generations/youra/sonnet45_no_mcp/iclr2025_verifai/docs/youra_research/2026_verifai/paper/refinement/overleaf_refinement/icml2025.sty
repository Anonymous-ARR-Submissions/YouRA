% ICML 2025 Style File (Minimal Version)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{icml2025}[2025/01/01 ICML 2025 Submission Style]

% Page layout
\RequirePackage[letterpaper,margin=1in]{geometry}
\RequirePackage{fancyhdr}

% Typography
\RequirePackage{times}
\RequirePackage{helvet}
\RequirePackage{courier}

% Graphics and tables
\RequirePackage{graphicx}
\RequirePackage{booktabs}
\RequirePackage{amsmath,amssymb,amsfonts}

% Hyperlinks
\RequirePackage{xcolor}
\RequirePackage{hyperref}
\hypersetup{
    colorlinks=true,
    linkcolor=blue,
    filecolor=magenta,
    urlcolor=cyan,
    citecolor=blue
}

% Title formatting
\newcommand{\icmltitlerunning}[1]{\gdef\@icmltitlerunning{#1}}
\newcommand{\icmltitle}[1]{\gdef\@icmltitle{#1}\title{#1}}

% Author list commands
\newcommand{\icmlsetsymbol}[2]{}
\newenvironment{icmlauthorlist}{}{}
\newcommand{\icmlauthor}[2]{#1\thanks{#2}}
\newcommand{\icmlaffiliation}[2]{}
\newcommand{\icmlcorrespondingauthor}[2]{}

% Keywords
\newcommand{\icmlkeywords}[1]{\par\vspace{0.1in}\noindent\textbf{Keywords:} #1}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Abstract
\renewenvironment{abstract}{%
  \par\noindent\textbf{Abstract}\par\vspace{0.5em}\noindent\ignorespaces
}{\par\vspace{1em}}

\endinput
