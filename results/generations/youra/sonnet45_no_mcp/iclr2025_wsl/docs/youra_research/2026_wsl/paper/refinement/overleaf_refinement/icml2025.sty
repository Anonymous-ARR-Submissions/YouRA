%% ICML 2025 Style File (Minimal Template)
%% Based on standard conference formatting

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{icml2025}[2025/01/01 ICML 2025 Proceedings Style]

% Page layout
\RequirePackage[letterpaper,margin=1in]{geometry}
\RequirePackage{fancyhdr}

% Typography
\RequirePackage{times}
\RequirePackage{helvet}
\RequirePackage{courier}

% Math and symbols
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{amsthm}

% Graphics
\RequirePackage{graphicx}
\RequirePackage{xcolor}

% References
\RequirePackage{natbib}

% Hyperlinks
\RequirePackage{hyperref}
\hypersetup{
  colorlinks=true,
  linkcolor=blue,
  citecolor=blue,
  urlcolor=blue
}

% Title formatting - Initialize variables
\def\@icmltitle{}
\def\@icmltitlerunning{}
\def\@icmlcorrespondingauthor{}
\def\@icmlkeywords{}

\newcommand{\icmltitlerunning}[1]{\def\@icmltitlerunning{#1}}
\newcommand{\icmltitle}[1]{\def\@icmltitle{#1}}
\newcommand{\icmlsetsymbol}[2]{}
\newenvironment{icmlauthorlist}{}{}
\newcommand{\icmlauthor}[2]{}
\newcommand{\icmlaffiliation}[2]{}
\newcommand{\icmlcorrespondingauthor}[2]{\def\@icmlcorrespondingauthor{#2}}
\newcommand{\icmlkeywords}[1]{\def\@icmlkeywords{#1}}

% Print title and authors
\newcommand{\printAffiliationsAndNotice}[1]{%
  \begin{center}
    {\LARGE\bfseries\@icmltitle\par}
    \vskip 0.2in
    {\large Corresponding author: \@icmlcorrespondingauthor\par}
    \vskip 0.1in
    {\itshape Keywords: \@icmlkeywords\par}
  \end{center}
  \vskip 0.3in
}

% Section formatting
\renewcommand{\section}{\@startsection{section}{1}{\z@}%
  {-3.5ex \@plus -1ex \@minus -.2ex}%
  {2.3ex \@plus.2ex}%
  {\normalfont\Large\bfseries}}

\renewcommand{\subsection}{\@startsection{subsection}{2}{\z@}%
  {-3.25ex\@plus -1ex \@minus -.2ex}%
  {1.5ex \@plus .2ex}%
  {\normalfont\large\bfseries}}

% Abstract environment
\renewenvironment{abstract}{%
  \small
  \begin{center}%
    \bfseries Abstract
  \end{center}%
  \quotation
}{\endquotation}

% Final version flag
\DeclareOption{final}{}
\ProcessOptions\relax

\endinput
