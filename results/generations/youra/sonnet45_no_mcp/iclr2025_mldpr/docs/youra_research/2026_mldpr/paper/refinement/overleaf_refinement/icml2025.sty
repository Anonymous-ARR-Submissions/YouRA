% ICML 2025 Style File (Simplified)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{icml2025}[2025/01/01 ICML 2025 Proceedings Style]

% Page layout
\RequirePackage[margin=1in]{geometry}
\RequirePackage{times}
\RequirePackage{fancyhdr}

% Title formatting
\newcommand{\icmltitlerunning}[1]{\def\@icmltitlerunning{#1}}
\newcommand{\icmltitle}[1]{\title{#1}}

% Author list
\newenvironment{icmlauthorlist}{}{}
\newcommand{\icmlauthor}[2]{\author{#1}}
\newcommand{\icmlaffiliation}[2]{}
\newcommand{\icmlcorrespondingauthor}[2]{}
\newcommand{\icmlsetsymbol}[2]{}
\newcommand{\icmlkeywords}[1]{\def\@icmlkeywords{#1}}
\newcommand{\printAffiliationsAndNotice}{}

% Headers
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\small\@icmltitlerunning}
\fancyhead[R]{\small\thepage}
\renewcommand{\headrulewidth}{0.4pt}

\endinput
