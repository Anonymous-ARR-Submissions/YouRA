% Minimal ICML 2025 Style File (Fallback)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{icml2025}[2025/01/01 ICML 2025 Submission Style]

% Page layout
\RequirePackage{geometry}
\geometry{letterpaper, margin=1in}

% Fonts and formatting
\RequirePackage{times}
\RequirePackage{helvet}
\RequirePackage{courier}

% Title formatting
\newcommand{\icmltitlerunning}[1]{\gdef\@icmltitlerunning{#1}}
\newcommand{\icmltitle}[1]{\title{#1}}
\newcommand{\icmlsetsymbol}[2]{}
\newenvironment{icmlauthorlist}{}{}
\newcommand{\icmlauthor}[2]{#1}
\newcommand{\icmlaffiliation}[2]{}
\newcommand{\icmlcorrespondingauthor}[2]{}
\newcommand{\icmlkeywords}[1]{}
\newcommand{\printAffiliationsAndNotice}{}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Bibliography style
\bibliographystyle{plain}

\endinput
