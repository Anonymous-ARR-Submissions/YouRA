% Minimal ICML 2025 style file (based on ICML 2024)
% This is a simplified version for compilation purposes

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{icml2025}[2024/01/01 ICML 2025 Proceedings Style]

% Required packages
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{graphicx}
\RequirePackage{natbib}
\RequirePackage{algorithm}
\RequirePackage{algorithmic}
\RequirePackage{hyperref}
\RequirePackage{url}
\RequirePackage{booktabs}

% Page layout
\setlength{\textheight}{8.875in}
\setlength{\textwidth}{6.875in}
\setlength{\columnsep}{0.3125in}
\setlength{\topmargin}{0in}
\setlength{\headheight}{0in}
\setlength{\headsep}{0in}
\setlength{\parindent}{1em}
\setlength{\oddsidemargin}{-.304in}
\setlength{\evensidemargin}{-.304in}

% Title commands
\newcommand{\icmltitlerunning}[1]{\gdef\@icmltitlerunning{#1}}
\newcommand{\icmltitle}[1]{\title{#1}\gdef\@icmltitle{#1}}
\newcommand{\icmlauthor}[2]{\gdef\@icmlauthor{#1}}
\newcommand{\icmlaffiliation}[2]{}
\newcommand{\icmlcorrespondingauthor}[2]{}
\newcommand{\icmlkeywords}[1]{\gdef\@icmlkeywords{#1}}
\newcommand{\icmlsetsymbol}[2]{}

% Author list
\newenvironment{icmlauthorlist}{}{}

% Print commands
\newcommand{\printAffiliationsAndNotice}{}

% Section formatting
\renewcommand{\section}{\@startsection{section}{1}{\z@}%
  {-3.5ex \@plus -1ex \@minus -.2ex}%
  {2.3ex \@plus.2ex}%
  {\normalfont\Large\bfseries}}

\renewcommand{\subsection}{\@startsection{subsection}{2}{\z@}%
  {-3.25ex\@plus -1ex \@minus -.2ex}%
  {1.5ex \@plus .2ex}%
  {\normalfont\large\bfseries}}

\renewcommand{\subsubsection}{\@startsection{subsubsection}{3}{\z@}%
  {-3.25ex\@plus -1ex \@minus -.2ex}%
  {1.5ex \@plus .2ex}%
  {\normalfont\normalsize\bfseries}}

% Bibliography style
\bibpunct{(}{)}{;}{a}{,}{,}

\endinput
