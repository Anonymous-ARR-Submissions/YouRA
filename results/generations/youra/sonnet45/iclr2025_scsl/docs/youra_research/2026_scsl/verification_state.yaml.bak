  h-e1:
    type: EXISTENCE
    statement: "Standard SSL training on Waterbirds creates geometrically separable\
      \ spurious feature clusters measurable via AMI, with AMI \u22650.4 predicting\
      \ cluster-balanced retraining efficacy (\u22652pp WGA gain) and AMI <0.3 yielding\
      \ <0.5pp gain"
    status: VALIDATED
