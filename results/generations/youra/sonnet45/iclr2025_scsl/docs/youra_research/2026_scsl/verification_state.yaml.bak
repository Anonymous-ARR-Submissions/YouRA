main_hypothesis:
  id: H-ClusterableSSL-v1
  title: Clusterability as Geometric Fairness Diagnostic for Self-Supervised Learning
  statement: "Under self-supervised learning on spurious correlation datasets (Waterbirds),\
    \ if embedding geometry exhibits high subgroup clusterability (AMI \u22650.4),\
    \ then cluster-balanced retraining improves worst-group accuracy by \u22652pp,\
    \ because spurious features manifest as geometrically separable density modes\
    \ that can be identified and reweighted without labels."
  defined_in: 03_refinement.yaml
  controlled_variables:
    dataset: Waterbirds
    model: SimCLR (ResNet-50), LA-SSL, ViT-H-14
    optimizer: SGD
    hyperparameters:
      learning_rate_range:
      - 0.01
      - 0.001
      - 0.0001
      weight_decay_range:
      - 0.0001
      - 1.0e-05
      - 1.0e-06
      epochs: 20
      batch_size: 32
      seeds: 5
  baseline_comparison:
