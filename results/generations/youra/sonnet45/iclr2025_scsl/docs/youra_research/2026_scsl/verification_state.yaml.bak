  h-m-integrated:
    type: MECHANISM
    statement: "The 3-step causal mechanism operates as: (M1) InfoNCE contrastive\
      \ loss creates dense spurious feature clusters (shared backgrounds) leading\
      \ to high AMI, (M2) High clusterability enables minority groups to occupy distinct\
      \ density modes exploitable by linear ERM and further improved by cluster-based\
      \ reweighting, (M3) LA-SSL learning-speed resampling disperses spurious density\
      \ structure (reducing AMI by \u226530%) while preserving linear separability\
      \ (\u0394AUC <0.05)"
    status: FAILED
    gate:
      type: MUST_WORK
      satisfied: false
      failed_checks:
        - M1 FAIL: AMI = 0.2795 (threshold >= 0.4)
        - M2 FAIL: Correlation = -1.0, p = 1.0 (threshold p < 0.05), no improvement
        - M3 FAIL: AMI increased 2% instead of decreasing 30%
      note: "POC experimental validation completed (20 epochs) - all mechanism gates failed with real data"
    prerequisites:
